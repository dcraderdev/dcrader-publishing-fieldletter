---
import { Picture, getImage } from 'astro:assets';
import Base from '../layouts/Base.astro';
import SubscribeBlock from '../components/SubscribeBlock.astro';
import IssueCard from '../components/IssueCard.astro';
import { site } from '../data/site';
import { currentIssue, issuesByDate } from '../data/issues';

const recent = issuesByDate.slice(1, 7);

// LCP candidate — preload the AVIF rendition of the hero cover at a representative size.
const heroPreload = await getImage({
  src: currentIssue.cover,
  format: 'avif',
  width: 1200,
});
---
<Base
  title={site.name}
  active="home"
  masthead
  preloadImage={heroPreload.src}
>
  <section class="max-w-wide mx-auto px-4 sm:px-6 lg:px-8 pt-10 sm:pt-14 pb-8">
    <p class="text-center font-sans text-xs uppercase tracking-[0.32em] text-ink-500">
      This week's issue · No. {currentIssue.number} · {currentIssue.section}
    </p>

    <div class="mt-6 grid gap-10 lg:grid-cols-12 lg:gap-12 items-start">
      <div class="lg:col-span-7">
        <a href={`/issues/${currentIssue.slug}/`} class="block group">
          <div class="overflow-hidden rounded border border-ink-900/10">
            <Picture
              src={currentIssue.cover}
              alt={currentIssue.coverAlt}
              formats={['avif', 'webp']}
              widths={[600, 1000, 1400, 1800]}
              sizes="(min-width: 1024px) 720px, 100vw"
              loading="eager"
              fetchpriority="high"
              decoding="async"
              class="w-full h-auto aspect-[3/2] object-cover group-hover:scale-[1.01] transition-transform duration-500"
            />
          </div>
        </a>
        <p class="mt-2 font-sans text-xs text-ink-500">{currentIssue.coverCredit}</p>
      </div>

      <div class="lg:col-span-5">
        <p class="font-sans text-sm text-ink-500">
          {currentIssue.displayDate} · {currentIssue.readingTime} min read
        </p>
        <h2 class="mt-2 font-display text-4xl sm:text-5xl text-ink-900 leading-[1.1] tracking-tight">
          <a href={`/issues/${currentIssue.slug}/`} class="hover:text-accent-700 transition-colors">
            {currentIssue.title}
          </a>
        </h2>
        <p class="mt-4 font-serif text-lg text-ink-700 leading-snug">
          {currentIssue.dek}
        </p>
        <p class="mt-3 font-sans text-sm text-ink-500">
          By {site.author}
        </p>
        <div class="mt-6">
          <a
            href={`/issues/${currentIssue.slug}/`}
            class="inline-flex items-center gap-2 rounded bg-ink-900 px-4 py-2.5 font-sans text-sm text-paper-50 hover:bg-ink-800 transition-colors"
          >
            Read the essay
            <svg aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
            </svg>
          </a>
        </div>

        <div class="mt-8">
          <SubscribeBlock variant="hero" />
        </div>
      </div>
    </div>
  </section>

  <hr class="max-w-wide mx-auto border-ink-900/10" />

  <section class="max-w-wide mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="flex items-baseline justify-between gap-4 mb-8">
      <h2 class="font-display text-2xl sm:text-3xl text-ink-900">Recent issues</h2>
      <a href="/archive/" class="font-sans text-sm text-accent-700 hover:text-accent-800">
        Browse the full archive →
      </a>
    </div>
    <div class="grid gap-x-8 gap-y-12 sm:grid-cols-2 lg:grid-cols-3">
      {recent.map((issue) => (
        <IssueCard issue={issue} />
      ))}
    </div>
  </section>
</Base>
