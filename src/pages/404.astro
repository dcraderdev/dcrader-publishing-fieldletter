---
import Base from '../layouts/Base.astro';
---
<Base
  title="Page not found"
  description="The page you were looking for has wandered off the trail."
>
  <section class="max-w-wide mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-28">
    <div class="max-w-essay mx-auto text-center">
      <p class="font-display text-[7rem] sm:text-[10rem] leading-none text-accent-700 tracking-tight">
        404
      </p>
      <h1 class="mt-4 font-display text-3xl sm:text-4xl text-ink-900 tracking-tight">
        Page not found
      </h1>
      <p class="mt-6 font-serif text-lg text-ink-700 leading-snug">
        Looks like this trail's been overgrown. The page you were after isn't here —
        maybe it was moved, retired, or never made it past the editor's desk.
      </p>
      <div class="mt-10">
        <a
          href="/"
          class="inline-flex items-center gap-2 rounded bg-ink-900 px-4 py-2.5 font-sans text-sm text-paper-50 hover:bg-ink-800 transition-colors"
        >
          <svg aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M19 12H5"/><path d="m12 19-7-7 7-7"/>
          </svg>
          Back to home
        </a>
      </div>
    </div>
  </section>
</Base>
</content>
</invoke>